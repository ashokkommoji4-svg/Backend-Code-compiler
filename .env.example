# ===============================================
# Code Compiler Backend - Environment Variables
# ===============================================
# Copy this file to .env and fill in your values

# ===============================================
# DJANGO SETTINGS
# ===============================================
DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ===============================================
# DATABASE CONFIGURATION
# ===============================================
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# PostgreSQL (for production)
# DB_ENGINE=django.db.backends.postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=code_compiler_db
# DB_USER=postgres
# DB_PASSWORD=your_secure_password

# ===============================================
# SERVER CONFIGURATION
# ===============================================
SERVER_PORT=8000
SERVER_HOST=127.0.0.1
DAPHNE_BIND=0.0.0.0:8000

# ===============================================
# CORS & FRONTEND SETTINGS
# ===============================================
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ===============================================
# CHANNELS & WEBSOCKET
# ===============================================
CHANNEL_LAYER_BACKEND=channels.layers.InMemoryChannelLayer
REDIS_URL=redis://localhost:6379/0

# ===============================================
# COMPILER/EXECUTOR SETTINGS
# ===============================================
EXECUTION_TIMEOUT=30
MAX_FILE_SIZE=5242880
SUPPORTED_LANGUAGES=python,javascript,java,c,cpp,go

# ===============================================
# EMAIL CONFIGURATION
# ===============================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ===============================================
# LOGGING
# ===============================================
LOG_LEVEL=INFO
LOG_FILE=logs/django.log

# ===============================================
# SECURITY SETTINGS
# ===============================================
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ===============================================
# STATIC & MEDIA FILES
# ===============================================
STATIC_URL=/static/
STATIC_ROOT=staticfiles/
MEDIA_URL=/media/
MEDIA_ROOT=media/

# ===============================================
# REST FRAMEWORK
# ===============================================
REST_FRAMEWORK_PAGE_SIZE=100
REST_FRAMEWORK_THROTTLE_RATE=1000/hour
